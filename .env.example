APP_NAME="FF Spotless"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8096

APP_LOCALE=ms
APP_FALLBACK_LOCALE=ms
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ffspotless
DB_USERNAME=ffspotless
DB_PASSWORD=replace-with-a-strong-local-password
DB_ROOT_PASSWORD=replace-with-a-strong-local-root-password
DB_TIMEZONE=+00:00

CHECKLIST_ADMIN_PASSWORD=12345678
CHECKLIST_ADMIN_SESSION_KEY=checklist_admin_authenticated
CHECKLIST_ADMIN_SESSION_MINUTES=120
CHECKLIST_TIMEZONE=Asia/Kuala_Lumpur
CHECKLIST_PAST_MATERIALIZATION_DAYS=365
CHECKLIST_FUTURE_MATERIALIZATION_DAYS=365

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
